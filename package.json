{
  "name": "@julr/tooling-configs",
  "type": "module",
  "version": "6.0.0",
  "packageManager": "pnpm@10.29.3",
  "description": "Shared tooling configs: ESLint, Prettier, TSConfig, OXC (oxlint + oxfmt)",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "MIT",
  "keywords": [
    "eslint-config",
    "flat",
    "oxlint",
    "oxfmt",
    "oxc",
    "prettier",
    "tsconfig"
  ],
  "exports": {
    "./prettier": "./dist/src/prettier/index.json",
    "./tsconfigs/*": "./dist/src/tsconfigs/*.json",
    "./eslint": "./dist/eslint/index.js",
    "./oxc/lint": "./dist/oxc/lint.js",
    "./oxc/fmt": "./dist/oxc/fmt.js"
  },
  "bin": "./dist/cli/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint .",
    "build": "tsup",
    "release": "pnpm build && release-it",
    "typecheck": "tsc --noEmit",
    "checks": "pnpm typecheck && pnpm lint"
  },
  "dependencies": {
    "@adonisjs/eslint-plugin": "^2.2.1",
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^1.0.1",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@unocss/eslint-plugin": "^66.6.0",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.5.5",
    "eslint-plugin-jsonc": "^2.21.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsonc-eslint-parser": "^2.4.2",
    "local-pkg": "^1.1.2",
    "picocolors": "^1.1.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "peerDependencies": {
    "oxfmt": ">=0.40.0",
    "oxlint": ">=1.55.0"
  },
  "peerDependenciesMeta": {
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.2.3",
    "cpy": "^13.2.1",
    "eslint": "^10.0.0",
    "eslint-flat-config-utils": "^3.0.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "release ${version}"
    },
    "github": {
      "release": true,
      "web": true
    }
  }
}
